# Copy this file to ".env" (same folder) and fill in your real values.
# Never commit the real ".env" — it's already excluded by .gitignore.

# MongoDB Atlas connection string (Atlas dashboard -> Connect -> Drivers).
# Looks like: mongodb+srv://<username>:<password>@<cluster-host>/?retryWrites=true&w=majority
MONGODB_URI=

# Name of the database to use.
DB_NAME=koyash
