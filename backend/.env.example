APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Authentication (ADR-004). Secret used to sign JWT access tokens. Generate a
# strong random value in production, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
# The application falls back to a dev-only default if this is unset.
JWT_SECRET=<random-secret>
# JWT_EXPIRE_DAYS=7

# LLM justification layer (ADR-001). Off unless LLM_ENABLED=true AND a key AND a
# system prompt are provided. The system prompt is customer-owned and not
# committed: put it in LLM_SYSTEM_PROMPT or the git-ignored
# backend/llm_system_prompt.txt (see backend/llm_system_prompt.example.txt).
LLM_ENABLED=false
LLM_API=<llm-api-key>
LLM_BASE_URL=https://api.vsellm.ru/v1
LLM_MODEL=openai/gpt-4o-mini
# LLM_SYSTEM_PROMPT=
